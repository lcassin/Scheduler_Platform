<Window x:Class="MermaidEditor.PrintPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Print Preview" Height="700" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ThemeBackgroundBrush}">
    
        <Window.Resources>
            <!-- Override system colors for ComboBox popup background -->
            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2D2D30"/>
        
            <Style TargetType="Label">
                <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
            </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource ThemeToolbarBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderBrush}"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource ThemeMenuBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ThemeToolbarBackgroundBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ThemeToolbarBackgroundBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ThemeToolbarBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderBrush}"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Settings Panel -->
        <Border Grid.Column="0" Background="{DynamicResource ThemeMenuBackgroundBrush}" Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Print Settings" FontSize="18" FontWeight="Bold" 
                               Foreground="{DynamicResource ThemeForegroundBrush}" Margin="0,0,0,16"/>
                    
                    <!-- Page Size -->
                    <GroupBox Header="Page Size">
                        <StackPanel Margin="8">
                            <ComboBox x:Name="PageSizeCombo" SelectionChanged="PageSizeCombo_SelectionChanged">
                                <ComboBoxItem Content="Letter (8.5 x 11 in)" IsSelected="True"/>
                                <ComboBoxItem Content="Legal (8.5 x 14 in)"/>
                                <ComboBoxItem Content="A4 (210 x 297 mm)"/>
                                <ComboBoxItem Content="A3 (297 x 420 mm)"/>
                                <ComboBoxItem Content="Tabloid (11 x 17 in)"/>
                            </ComboBox>
                        </StackPanel>
                    </GroupBox>
                    
                    <!-- Orientation -->
                    <GroupBox Header="Orientation">
                        <StackPanel Margin="8">
                            <RadioButton x:Name="PortraitRadio" Content="Portrait" IsChecked="True" 
                                         Checked="Orientation_Changed"/>
                            <RadioButton x:Name="LandscapeRadio" Content="Landscape" 
                                         Checked="Orientation_Changed"/>
                        </StackPanel>
                    </GroupBox>
                    
                    <!-- Scaling -->
                    <GroupBox Header="Scaling">
                        <StackPanel Margin="8">
                            <RadioButton x:Name="FitToPageRadio" Content="Fit to single page" IsChecked="True"
                                         Checked="Scaling_Changed"/>
                            <RadioButton x:Name="FitToWidthRadio" Content="Fit to page width (may span multiple pages)"
                                         Checked="Scaling_Changed"/>
                            <RadioButton x:Name="ActualSizeRadio" Content="Actual size (100%)"
                                         Checked="Scaling_Changed"/>
                        </StackPanel>
                    </GroupBox>
                    
                    <!-- Margins -->
                    <GroupBox Header="Margins">
                        <StackPanel Margin="8">
                            <ComboBox x:Name="MarginsCombo" SelectionChanged="MarginsCombo_SelectionChanged">
                                <ComboBoxItem Content="Normal (1 inch)" IsSelected="True"/>
                                <ComboBoxItem Content="Narrow (0.5 inch)"/>
                                <ComboBoxItem Content="Wide (1.5 inch)"/>
                                <ComboBoxItem Content="None"/>
                            </ComboBox>
                        </StackPanel>
                    </GroupBox>
                    
                    <!-- Options -->
                    <GroupBox Header="Options">
                        <StackPanel Margin="8">
                            <CheckBox x:Name="PrintBackgroundCheck" Content="Print background colors" IsChecked="True"
                                      Checked="Options_Changed" Unchecked="Options_Changed"/>
                            <CheckBox x:Name="CenterOnPageCheck" Content="Center on page" IsChecked="True"
                                      Checked="Options_Changed" Unchecked="Options_Changed"/>
                        </StackPanel>
                    </GroupBox>
                    
                    <!-- Page Info -->
                    <Border Background="{DynamicResource ThemeToolbarBackgroundBrush}" 
                            CornerRadius="4" Padding="12" Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock x:Name="PageCountText" Text="Pages: 1" 
                                       Foreground="{DynamicResource ThemeForegroundBrush}"/>
                            <TextBlock x:Name="ScaleText" Text="Scale: 100%" 
                                       Foreground="{DynamicResource ThemeForegroundBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                        <Button x:Name="PrintButton" Content="Print" Click="Print_Click" IsDefault="True"/>
                        <Button Content="Cancel" Click="Cancel_Click" IsCancel="True"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
        
        <!-- Preview Panel -->
        <Border Grid.Column="1" Background="{DynamicResource ThemeBackgroundBrush}" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="Preview" FontSize="16" FontWeight="SemiBold" 
                           Foreground="{DynamicResource ThemeForegroundBrush}" Margin="0,0,0,8"/>
                
                <!-- Preview Area -->
                <Border Grid.Row="1" Background="#404040" CornerRadius="4">
                    <ScrollViewer x:Name="PreviewScrollViewer" 
                                  HorizontalScrollBarVisibility="Auto" 
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="16">
                        <StackPanel x:Name="PreviewPagesPanel" HorizontalAlignment="Center">
                            <!-- Pages will be added here dynamically -->
                        </StackPanel>
                    </ScrollViewer>
                </Border>
                
                <!-- Page Navigation -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                    <Button x:Name="PrevPageButton" Content="Previous" Click="PrevPage_Click" IsEnabled="False"/>
                    <TextBlock x:Name="CurrentPageText" Text="Page 1 of 1" VerticalAlignment="Center" 
                               Foreground="{DynamicResource ThemeForegroundBrush}" Margin="16,0"/>
                    <Button x:Name="NextPageButton" Content="Next" Click="NextPage_Click" IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

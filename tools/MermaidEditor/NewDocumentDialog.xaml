<Window x:Class="MermaidEditor.NewDocumentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Document" 
        Height="550" Width="850"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ThemeBackgroundBrush}"
        ResizeMode="NoResize">
    <Window.Resources>
        <!-- Override system colors for popup selection theming -->
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="{DynamicResource ThemeBorderColor}"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{DynamicResource ThemeAccentColor}"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="{DynamicResource ThemeBorderColor}"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="{DynamicResource ThemeForegroundColor}"/>

        <!-- ScrollViewer Style for theme support -->
        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        
        <!-- Dark ScrollBar Thumb -->
        <Style x:Key="DarkScrollBarThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="thumbBorder" Background="{DynamicResource ThemeSliderThumbBrush}" CornerRadius="4" 
                                Margin="2" MinHeight="18" MinWidth="18"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="thumbBorder" Property="Background" Value="{DynamicResource ThemeSliderThumbHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="thumbBorder" Property="Background" Value="{DynamicResource ThemeSliderThumbHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkScrollBarLineButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{DynamicResource ThemeBorderBrush}" Height="0" Width="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkScrollBarPageButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="DarkVerticalScrollBar" TargetType="ScrollBar">
            <Grid Background="{DynamicResource ThemeToolbarBackgroundBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <RepeatButton Grid.Row="0" Style="{StaticResource DarkScrollBarLineButton}" Command="ScrollBar.LineUpCommand"/>
                <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource DarkScrollBarPageButton}" Command="ScrollBar.PageUpCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource DarkScrollBarThumb}"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource DarkScrollBarPageButton}" Command="ScrollBar.PageDownCommand"/>
                    </Track.IncreaseRepeatButton>
                </Track>
                <RepeatButton Grid.Row="2" Style="{StaticResource DarkScrollBarLineButton}" Command="ScrollBar.LineDownCommand"/>
            </Grid>
        </ControlTemplate>

        <Style TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="MinWidth" Value="12"/>
            <Setter Property="Template" Value="{StaticResource DarkVerticalScrollBar}"/>
        </Style>
        
        <!-- Dropdown toggle button for split-button -->
        <Style x:Key="DropdownToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="toggleBorder" Background="{TemplateBinding Background}" 
                                BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1,0,0,0"
                                CornerRadius="0,4,4,0" Padding="6,0">
                            <Path x:Name="Arrow" Data="M 0 0 L 5 5 L 10 0 Z" 
                                  Fill="{DynamicResource ThemeForegroundBrush}" 
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Width="10" Height="6" Stretch="Uniform"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="toggleBorder" Property="Background" Value="{DynamicResource ThemeHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="toggleBorder" Property="Background" Value="{DynamicResource ThemeHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dropdown popup item style -->
        <Style x:Key="DropdownItemStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="itemBorder" Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="{DynamicResource ThemeAccentBrush}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="TemplateButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ThemeToolbarBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ThemeHoverBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource ThemePurpleAccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="RecentFileButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ThemeHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="Create or open a document:" 
                   Foreground="{DynamicResource ThemeForegroundBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
        
        <!-- Two-column layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left column: Open existing / Recent files -->
            <Border Grid.Column="0" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Open" Foreground="{DynamicResource ThemeForegroundBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    
                    <Button Grid.Row="1" Style="{StaticResource TemplateButtonStyle}" Click="OpenExistingFile_Click" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="24" VerticalAlignment="Center" Margin="4,0,12,0"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Browse..." FontWeight="SemiBold"/>
                                <TextBlock Text="Open an existing file" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>
                    
                    <TextBlock Grid.Row="2" Text="Recent Files" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="12" Margin="0,0,0,8"/>
                    
                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="RecentFilesPanel">
                            <TextBlock x:Name="NoRecentFilesText" Text="No recent files" 
                                       Foreground="{DynamicResource ThemeDisabledForegroundBrush}" 
                                       FontStyle="Italic" Margin="8,4"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
            
            <!-- Right column: New templates -->
            <Border Grid.Column="2" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="New (Select a template)" Foreground="{DynamicResource ThemeForegroundBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Blank" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="12" Margin="4,0,0,4"/>
                            <!-- Split-button: Blank Mermaid Diagram with diagram type dropdown overlay -->
                            <Grid>
                                <Button Style="{StaticResource TemplateButtonStyle}" Click="BlankMermaid_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <Image x:Name="BlankDiagramTypeIcon" Source="Resources/TemplateThumbnails/flowchart.png" Width="36" Height="36" Margin="0,0,10,0"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Blank Mermaid Diagram — " FontWeight="SemiBold"/>
                                                <TextBlock x:Name="BlankDiagramTypeLabel" Text="Flowchart" FontWeight="SemiBold" 
                                                           Foreground="{DynamicResource ThemePurpleAccentBrush}"/>
                                            </StackPanel>
                                            <TextBlock Text="Start with a minimal diagram of the selected type" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Button>
                                <!-- Dropdown toggle arrow on the right side of the button -->
                                <ToggleButton x:Name="DiagramTypeDropdownToggle" 
                                              Style="{StaticResource DropdownToggleStyle}"
                                              HorizontalAlignment="Right" VerticalAlignment="Stretch"
                                              Width="28" Margin="0,5,5,5"/>
                                <!-- Popup dropdown with diagram type list -->
                                <Popup IsOpen="{Binding IsChecked, ElementName=DiagramTypeDropdownToggle}"
                                       PlacementTarget="{Binding ElementName=DiagramTypeDropdownToggle}"
                                       Placement="Bottom"
                                       StaysOpen="False"
                                       AllowsTransparency="True"
                                       PopupAnimation="Slide">
                                    <Border Background="{DynamicResource ThemeToolbarBackgroundBrush}" 
                                            BorderBrush="{DynamicResource ThemeBorderBrush}" 
                                            BorderThickness="1" CornerRadius="4" Padding="2"
                                            Margin="0,2,0,0">
                                        <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                                            <StackPanel>
                                                <Button Style="{StaticResource DropdownItemStyle}" Tag="Flowchart" Click="DiagramTypeItem_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="Resources/TemplateThumbnails/flowchart.png" Width="20" Height="20" Margin="0,0,8,0"/>
                                                        <TextBlock Text="Flowchart" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource DropdownItemStyle}" Tag="Sequence" Click="DiagramTypeItem_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="Resources/TemplateThumbnails/sequence.png" Width="20" Height="20" Margin="0,0,8,0"/>
                                                        <TextBlock Text="Sequence" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource DropdownItemStyle}" Tag="Class" Click="DiagramTypeItem_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="Resources/TemplateThumbnails/class.png" Width="20" Height="20" Margin="0,0,8,0"/>
                                                        <TextBlock Text="Class" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource DropdownItemStyle}" Tag="State" Click="DiagramTypeItem_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="Resources/TemplateThumbnails/state.png" Width="20" Height="20" Margin="0,0,8,0"/>
                                                        <TextBlock Text="State" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource DropdownItemStyle}" Tag="ER" Click="DiagramTypeItem_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="Resources/TemplateThumbnails/erdiagram.png" Width="20" Height="20" Margin="0,0,8,0"/>
                                                        <TextBlock Text="ER Diagram" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource DropdownItemStyle}" Tag="Gantt" Click="DiagramTypeItem_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="Resources/TemplateThumbnails/gantt.png" Width="20" Height="20" Margin="0,0,8,0"/>
                                                        <TextBlock Text="Gantt" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource DropdownItemStyle}" Tag="Pie" Click="DiagramTypeItem_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="Resources/TemplateThumbnails/pie.png" Width="20" Height="20" Margin="0,0,8,0"/>
                                                        <TextBlock Text="Pie Chart" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource DropdownItemStyle}" Tag="MindMap" Click="DiagramTypeItem_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="Resources/TemplateThumbnails/mindmap.png" Width="20" Height="20" Margin="0,0,8,0"/>
                                                        <TextBlock Text="Mind Map" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource DropdownItemStyle}" Tag="Timeline" Click="DiagramTypeItem_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="Resources/TemplateThumbnails/timeline.png" Width="20" Height="20" Margin="0,0,8,0"/>
                                                        <TextBlock Text="Timeline" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource DropdownItemStyle}" Tag="Git Graph" Click="DiagramTypeItem_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="Resources/TemplateThumbnails/gitgraph.png" Width="20" Height="20" Margin="0,0,8,0"/>
                                                        <TextBlock Text="Git Graph" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource DropdownItemStyle}" Tag="Journey" Click="DiagramTypeItem_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="Resources/TemplateThumbnails/journey.png" Width="20" Height="20" Margin="0,0,8,0"/>
                                                        <TextBlock Text="Journey" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource DropdownItemStyle}" Tag="Quadrant" Click="DiagramTypeItem_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="Resources/TemplateThumbnails/quadrant.png" Width="20" Height="20" Margin="0,0,8,0"/>
                                                        <TextBlock Text="Quadrant" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource DropdownItemStyle}" Tag="Requirement" Click="DiagramTypeItem_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="Resources/TemplateThumbnails/requirement.png" Width="20" Height="20" Margin="0,0,8,0"/>
                                                        <TextBlock Text="Requirement" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource DropdownItemStyle}" Tag="C4" Click="DiagramTypeItem_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="Resources/TemplateThumbnails/c4.png" Width="20" Height="20" Margin="0,0,8,0"/>
                                                        <TextBlock Text="C4 Context" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                            <Button Style="{StaticResource TemplateButtonStyle}" Click="BlankMarkdown_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="Resources/TemplateThumbnails/markdown.png" Width="36" Height="36" Margin="0,0,10,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Blank Markdown Document" FontWeight="SemiBold"/>
                                        <TextBlock Text="Start with an empty .md file" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                
                            <TextBlock Text="Markdown" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="12" Margin="4,12,0,4"/>
                            <Button Style="{StaticResource TemplateButtonStyle}" Click="MarkdownCheatSheet_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="Resources/TemplateThumbnails/markdown.png" Width="36" Height="36" Margin="0,0,10,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Markdown Cheat Sheet" FontWeight="SemiBold"/>
                                        <TextBlock Text="All markdown syntax with live preview examples" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                
                            <TextBlock Text="Flowcharts" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="12" Margin="4,12,0,4"/>
                            <Button Style="{StaticResource TemplateButtonStyle}" Click="Flowchart_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="Resources/TemplateThumbnails/flowchart.png" Width="36" Height="36" Margin="0,0,10,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Flowchart" FontWeight="SemiBold"/>
                                        <TextBlock Text="Basic flowchart with nodes and connections" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource TemplateButtonStyle}" Click="FlowchartAdvanced_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="Resources/TemplateThumbnails/flowchart.png" Width="36" Height="36" Margin="0,0,10,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Flowchart (Advanced)" FontWeight="SemiBold"/>
                                        <TextBlock Text="Flowchart with subgraphs and styling" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                
                            <TextBlock Text="Sequence Diagrams" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="12" Margin="4,12,0,4"/>
                            <Button Style="{StaticResource TemplateButtonStyle}" Click="Sequence_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="Resources/TemplateThumbnails/sequence.png" Width="36" Height="36" Margin="0,0,10,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Sequence Diagram" FontWeight="SemiBold"/>
                                        <TextBlock Text="Interactions between participants" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                
                            <TextBlock Text="Class Diagrams" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="12" Margin="4,12,0,4"/>
                            <Button Style="{StaticResource TemplateButtonStyle}" Click="ClassDiagram_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="Resources/TemplateThumbnails/class.png" Width="36" Height="36" Margin="0,0,10,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Class Diagram" FontWeight="SemiBold"/>
                                        <TextBlock Text="UML class diagram with relationships" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                
                            <TextBlock Text="State Diagrams" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="12" Margin="4,12,0,4"/>
                            <Button Style="{StaticResource TemplateButtonStyle}" Click="StateDiagram_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="Resources/TemplateThumbnails/state.png" Width="36" Height="36" Margin="0,0,10,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="State Diagram" FontWeight="SemiBold"/>
                                        <TextBlock Text="State machine with transitions" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                
                            <TextBlock Text="Entity Relationship" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="12" Margin="4,12,0,4"/>
                            <Button Style="{StaticResource TemplateButtonStyle}" Click="ERDiagram_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="Resources/TemplateThumbnails/erdiagram.png" Width="36" Height="36" Margin="0,0,10,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="ER Diagram" FontWeight="SemiBold"/>
                                        <TextBlock Text="Database entity relationship diagram" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                
                            <TextBlock Text="Gantt Charts" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="12" Margin="4,12,0,4"/>
                            <Button Style="{StaticResource TemplateButtonStyle}" Click="Gantt_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="Resources/TemplateThumbnails/gantt.png" Width="36" Height="36" Margin="0,0,10,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Gantt Chart" FontWeight="SemiBold"/>
                                        <TextBlock Text="Project timeline with tasks" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                
                            <TextBlock Text="Pie Charts" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="12" Margin="4,12,0,4"/>
                            <Button Style="{StaticResource TemplateButtonStyle}" Click="Pie_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="Resources/TemplateThumbnails/pie.png" Width="36" Height="36" Margin="0,0,10,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Pie Chart" FontWeight="SemiBold"/>
                                        <TextBlock Text="Simple pie chart with percentages" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                
                            <TextBlock Text="Mind Maps" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="12" Margin="4,12,0,4"/>
                            <Button Style="{StaticResource TemplateButtonStyle}" Click="Mindmap_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="Resources/TemplateThumbnails/mindmap.png" Width="36" Height="36" Margin="0,0,10,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Mind Map" FontWeight="SemiBold"/>
                                        <TextBlock Text="Hierarchical mind map" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                
                            <TextBlock Text="Timelines" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="12" Margin="4,12,0,4"/>
                            <Button Style="{StaticResource TemplateButtonStyle}" Click="Timeline_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="Resources/TemplateThumbnails/timeline.png" Width="36" Height="36" Margin="0,0,10,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Timeline" FontWeight="SemiBold"/>
                                        <TextBlock Text="Chronological timeline of events" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                
                            <TextBlock Text="Git Graphs" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="12" Margin="4,12,0,4"/>
                            <Button Style="{StaticResource TemplateButtonStyle}" Click="GitGraph_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="Resources/TemplateThumbnails/gitgraph.png" Width="36" Height="36" Margin="0,0,10,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Git Graph" FontWeight="SemiBold"/>
                                        <TextBlock Text="Git branch and commit visualization" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                
                            <TextBlock Text="User Journeys" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="12" Margin="4,12,0,4"/>
                            <Button Style="{StaticResource TemplateButtonStyle}" Click="Journey_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="Resources/TemplateThumbnails/journey.png" Width="36" Height="36" Margin="0,0,10,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="User Journey" FontWeight="SemiBold"/>
                                        <TextBlock Text="User experience journey map" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                
                            <TextBlock Text="Quadrant Charts" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="12" Margin="4,12,0,4"/>
                            <Button Style="{StaticResource TemplateButtonStyle}" Click="Quadrant_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="Resources/TemplateThumbnails/quadrant.png" Width="36" Height="36" Margin="0,0,10,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Quadrant Chart" FontWeight="SemiBold"/>
                                        <TextBlock Text="Four-quadrant analysis chart" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                
                            <TextBlock Text="Requirement Diagrams" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="12" Margin="4,12,0,4"/>
                            <Button Style="{StaticResource TemplateButtonStyle}" Click="Requirement_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="Resources/TemplateThumbnails/requirement.png" Width="36" Height="36" Margin="0,0,10,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Requirement Diagram" FontWeight="SemiBold"/>
                                        <TextBlock Text="Requirements traceability" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                
                            <TextBlock Text="C4 Diagrams" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="12" Margin="4,12,0,4"/>
                            <Button Style="{StaticResource TemplateButtonStyle}" Click="C4_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="Resources/TemplateThumbnails/c4.png" Width="36" Height="36" Margin="0,0,10,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="C4 Context Diagram" FontWeight="SemiBold"/>
                                        <TextBlock Text="System context with people and systems" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Width="80" Padding="8,6" Click="Cancel_Click"
                    Background="{DynamicResource ThemeToolbarBackgroundBrush}" 
                    Foreground="{DynamicResource ThemeForegroundBrush}" 
                    BorderBrush="{DynamicResource ThemeBorderBrush}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ThemeHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>

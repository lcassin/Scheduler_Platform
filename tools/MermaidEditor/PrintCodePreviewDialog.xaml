<Window x:Class="MermaidEditor.PrintCodePreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Print Code Preview" Height="700" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ThemeBackgroundBrush}">
    
                <Window.Resources>
                    <!-- Override system colors for ComboBox popup and selection -->
                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#3E3E42"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#007ACC"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#3E3E42"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#F1F1F1"/>
        
                    <!-- Dark ComboBox Toggle Button Template -->
                    <ControlTemplate x:Key="DarkComboBoxToggleButton" TargetType="ToggleButton">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="20"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Border" Grid.ColumnSpan="2" Background="#3E3E42" BorderBrush="#555555" BorderThickness="1" CornerRadius="2"/>
                            <Border Grid.Column="0" Background="#3E3E42" BorderBrush="Transparent" BorderThickness="0" CornerRadius="2,0,0,2"/>
                            <Path x:Name="Arrow" Grid.Column="1" Fill="#F1F1F1" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#4E4E52"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#4E4E52"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
        
                    <!-- Dark ComboBox Template -->
                    <ControlTemplate x:Key="DarkComboBoxTemplate" TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Template="{StaticResource DarkComboBoxToggleButton}" 
                                          Focusable="False" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                          ClickMode="Press"/>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" 
                                              Content="{TemplateBinding SelectionBoxItem}" 
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" 
                                              Margin="8,4,28,4" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#F1F1F1"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" 
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#2D2D30" BorderBrush="#555555" BorderThickness="1"/>
                                    <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
        
                    <Style TargetType="Label">
                        <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
                    </Style>
                    <Style TargetType="ComboBox">
                    <Setter Property="Template" Value="{StaticResource DarkComboBoxTemplate}"/>
                    <Setter Property="Foreground" Value="#F1F1F1"/>
                </Style>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background" Value="#2D2D30"/>
                    <Setter Property="Foreground" Value="#F1F1F1"/>
                    <Setter Property="Padding" Value="8,4"/>
                    <Style.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter Property="Background" Value="#007ACC"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#3E3E42"/>
                            <Setter Property="Foreground" Value="#F1F1F1"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ThemeToolbarBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderBrush}"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Settings Panel -->
        <Border Grid.Column="0" Background="{DynamicResource ThemeMenuBackgroundBrush}" Padding="16">
            <StackPanel>
                <TextBlock Text="Print Settings" FontSize="18" FontWeight="Bold" 
                           Foreground="{DynamicResource ThemeForegroundBrush}" Margin="0,0,0,16"/>
                
                <!-- Font Size -->
                <GroupBox Header="Font Size">
                    <StackPanel Margin="8">
                        <ComboBox x:Name="FontSizeCombo" SelectionChanged="FontSizeCombo_SelectionChanged">
                            <ComboBoxItem Content="8 pt"/>
                            <ComboBoxItem Content="9 pt"/>
                            <ComboBoxItem Content="10 pt" IsSelected="True"/>
                            <ComboBoxItem Content="11 pt"/>
                            <ComboBoxItem Content="12 pt"/>
                        </ComboBox>
                    </StackPanel>
                </GroupBox>
                
                <!-- Options -->
                <GroupBox Header="Options">
                    <StackPanel Margin="8">
                        <CheckBox x:Name="ShowLineNumbersCheckBox" Content="Show line numbers" 
                                  Foreground="{DynamicResource ThemeForegroundBrush}"
                                  Checked="ShowLineNumbers_Changed" Unchecked="ShowLineNumbers_Changed"
                                  Margin="0,0,0,8"/>
                        <CheckBox x:Name="WordWrapCheckBox" Content="Word wrap" IsChecked="True"
                                  Foreground="{DynamicResource ThemeForegroundBrush}"
                                  Checked="WordWrap_Changed" Unchecked="WordWrap_Changed"/>
                    </StackPanel>
                </GroupBox>
                
                <!-- Page Info -->
                <Border Background="{DynamicResource ThemeToolbarBackgroundBrush}" 
                        CornerRadius="4" Padding="12" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock x:Name="LineCountText" Text="Lines: 0" 
                                   Foreground="{DynamicResource ThemeForegroundBrush}"/>
                    </StackPanel>
                </Border>
                
                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                    <Button x:Name="PrintButton" Content="Print" Click="Print_Click" IsDefault="True"/>
                    <Button Content="Cancel" Click="Cancel_Click" IsCancel="True"/>
                </StackPanel>
            </StackPanel>
        </Border>
        
        <!-- Preview Panel -->
        <Border Grid.Column="1" Background="{DynamicResource ThemeBackgroundBrush}" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="Preview" FontSize="16" FontWeight="SemiBold" 
                           Foreground="{DynamicResource ThemeForegroundBrush}" Margin="0,0,0,8"/>
                
                <!-- Preview Area -->
                <Border Grid.Row="1" Background="White" CornerRadius="4" Padding="16">
                    <FlowDocumentScrollViewer x:Name="PreviewViewer" 
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Auto"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>

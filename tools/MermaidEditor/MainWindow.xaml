                                        <Path Data="M17.296 12.5H6.5C5.09554 12.5 4.39331 12.5 3.88886 12.8371C3.67048 12.983 3.48298 13.1705 3.33706 13.3889C3 13.8933 3 14.5955 3 16C3 17.4045 3 18.1067 3.33706 18.6111C3.48298 18.8295 3.67048 19.017 3.88886 19.1629C4.39331 19.5 5.09554 19.5 6.5 19.5H17.296C17.9536 19.5 18.2824 19.5 18.5841 19.4018C18.7172 19.3585 18.8454 19.3013 18.9665 19.2312C19.2412 19.0723 19.4608 18.8277 19.9002 18.3384C20.7509 17.3911 21.1762 16.9174 21.2786 16.3638C21.3231 16.1233 21.3231 15.8767 21.2786 15.6362C21.1762 15.0826 20.7509 14.6089 19.9002 13.6616C19.4608 13.1723 19.2412 12.9277 18.9665 12.7688C18.8454 12.6987 18.7172 12.6415 18.5841 12.5982C18.2824 12.5 17.9536 12.5 17.296 12.5Z" Stroke="{DynamicResource ThemeForegroundBrush}" StrokeThickness="1.5"/>
                                        <Path Data="M12.75 20C12.75 19.5858 12.4142 19.25 12 19.25C11.5858 19.25 11.25 19.5858 11.25 20H12.75ZM14 22.75C14.4142 22.75 14.75 22.4142 14.75 22C14.75 21.5858 14.4142 21.25 14 21.25V22.75ZM10 21.25C9.58579 21.25 9.25 21.5858 9.25 22C9.25 22.4142 9.58579 22.75 10 22.75V21.25ZM11.25 20V22H12.75V20H11.25ZM14 21.25H10V22.75H14V21.25Z" Fill="{DynamicResource ThemeForegroundBrush}" Opacity="0.5"/>
                                        <Path Data="M9 7H15" Stroke="{DynamicResource ThemeForegroundBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0.5"/>
                                        <Path Data="M9 16L15 16" Stroke="{DynamicResource ThemeForegroundBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0.5"/>
                                    </Canvas>
                                </Viewbox>
                            </ToggleButton>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- Code Editor with purple border on right and subtle grey border on bottom -->
                <Border Grid.Row="1"
                        BorderBrush="{DynamicResource ThemePurpleAccentBrush}" 
                        BorderThickness="0,0,1,0"
                        Background="{DynamicResource ThemeBackgroundBrush}">
                    <Border BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition x:Name="MinimapColumn" Width="0"/>
                            </Grid.ColumnDefinitions>
                        <avalon:TextEditor x:Name="CodeEditor" 
                                 Grid.Column="0"
                                 FontFamily="Consolas"
                                 FontSize="14"
                                 Background="{DynamicResource ThemeEditorBackgroundBrush}"
                                 Foreground="{DynamicResource ThemeEditorForegroundBrush}"
                                 ShowLineNumbers="True"
                                 WordWrap="False"
                                 HorizontalScrollBarVisibility="Auto"
                                 VerticalScrollBarVisibility="Auto"/>
                        <!-- Minimap Panel -->
                        <Border x:Name="MinimapBorder" 
                                Grid.Column="1" 
                                Background="{DynamicResource ThemeEditorBackgroundBrush}"
                                BorderBrush="{DynamicResource ThemeBorderBrush}"
                                BorderThickness="1,0,0,0"
                                ClipToBounds="True"
                                Visibility="Collapsed">
                            <Grid>
                                <avalon:TextEditor x:Name="MinimapEditor"
                                         FontFamily="Consolas"
                                         FontSize="2"
                                         Background="{DynamicResource ThemeEditorBackgroundBrush}"
                                         Foreground="{DynamicResource ThemeEditorForegroundBrush}"
                                         ShowLineNumbers="False"
                                         WordWrap="False"
                                         IsReadOnly="True"
                                         HorizontalScrollBarVisibility="Hidden"
                                         VerticalScrollBarVisibility="Hidden"
                                         IsHitTestVisible="False"/>
                                <!-- Viewport indicator overlay - use Grid with Canvas for proper sizing -->
                                <Grid x:Name="MinimapOverlayGrid"
                                      Background="Transparent"
                                      MouseLeftButtonDown="MinimapViewport_MouseLeftButtonDown"
                                      MouseMove="MinimapViewport_MouseMove"
                                      MouseLeftButtonUp="MinimapViewport_MouseLeftButtonUp"
                                      MouseWheel="MinimapOverlay_MouseWheel"
                                      SizeChanged="MinimapViewport_SizeChanged">
                                    <Canvas x:Name="MinimapViewportCanvas" 
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch">
                                        <Border x:Name="MinimapViewportIndicator"
                                                Background="#50888888"
                                                BorderBrush="{DynamicResource ThemePurpleAccentBrush}"
                                                BorderThickness="2"
                                                CornerRadius="2"
                                                IsHitTestVisible="False"/>
                                    </Canvas>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Border>
            </Grid>
            
            <!-- Splitter between Code Editor and Visual Editor (visible in Split Mode) -->
            <GridSplitter x:Name="VisualEditorSplitter" Grid.Row="2" Grid.Column="1" 
                          Width="8" 
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource ThemeBorderBrush}"
                          Cursor="SizeWE"
                          Visibility="Collapsed">
                <GridSplitter.Template>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Background="{DynamicResource ThemeBorderBrush}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Ellipse Width="4" Height="4" Fill="{DynamicResource ThemeDisabledForegroundBrush}" Margin="0,2"/>
                                <Ellipse Width="4" Height="4" Fill="{DynamicResource ThemeDisabledForegroundBrush}" Margin="0,2"/>
                                <Ellipse Width="4" Height="4" Fill="{DynamicResource ThemeDisabledForegroundBrush}" Margin="0,2"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </GridSplitter.Template>
            </GridSplitter>
            
            <!-- Visual Editor Panel -->
            <Grid x:Name="VisualEditorPanel" Grid.Row="2" Grid.Column="2" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Border Grid.Row="0" Background="{DynamicResource ThemeToolbarBackgroundBrush}" Padding="8,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE8B1;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource ThemeForegroundBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="Visual Editor" Foreground="{DynamicResource ThemeForegroundBrush}" FontWeight="SemiBold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel x:Name="VisualHeaderModeButtons" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <ToggleButton x:Name="VisualHeaderTextModeToggle" Click="TextMode_Click" ToolTip="Code View Mode" Style="{StaticResource ToolbarToggleButtonStyle}" Padding="4,2">
                                <Viewbox Width="14" Height="14">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M16 11L17.6965 12.5268C19.239 13.9151 20.0103 14.6093 20.0103 15.5C20.0103 16.3907 19.239 17.0849 17.6965 18.4732L16 20" Stroke="{DynamicResource ThemeForegroundBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        <Path Data="M13.9868 5L10 20" Stroke="{DynamicResource ThemeForegroundBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0.5"/>
                                        <Path Data="M8.00005 4.82959L6.30358 6.35641C4.76102 7.74471 3.98975 8.43886 3.98975 9.32959C3.98975 10.2203 4.76102 10.9145 6.30358 12.3028L8.00005 13.8296" Stroke="{DynamicResource ThemeForegroundBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </ToggleButton>
                            <ToggleButton x:Name="VisualHeaderVisualModeToggle" Click="VisualMode_Click" ToolTip="Visual Editor Mode" Style="{StaticResource ToolbarToggleButtonStyle}" Padding="4,2">
                                <Viewbox Width="14" Height="14">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M9 11.5C9 12.8807 7.88071 14 6.5 14C5.11929 14 4 12.8807 4 11.5C4 10.1193 5.11929 9 6.5 9C7.88071 9 9 10.1193 9 11.5Z" Stroke="{DynamicResource ThemeForegroundBrush}" StrokeThickness="1.5"/>
                                        <Path Data="M14.3206 16.8017L9 13.29" Stroke="{DynamicResource ThemeForegroundBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0.5"/>
                                        <Path Data="M14.4207 6.83984L9.1001 10.3515" Stroke="{DynamicResource ThemeForegroundBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0.5"/>
                                        <Path Data="M19 18.5C19 19.8807 17.8807 21 16.5 21C15.1193 21 14 19.8807 14 18.5C14 17.1193 15.1193 16 16.5 16C17.8807 16 19 17.1193 19 18.5Z" Stroke="{DynamicResource ThemeForegroundBrush}" StrokeThickness="1.5"/>
                                        <Path Data="M19 5.5C19 6.88071 17.8807 8 16.5 8C15.1193 8 14 6.88071 14 5.5C14 4.11929 15.1193 3 16.5 3C17.8807 3 19 4.11929 19 5.5Z" Stroke="{DynamicResource ThemeForegroundBrush}" StrokeThickness="1.5"/>
                                    </Canvas>
                                </Viewbox>
                            </ToggleButton>
                            <ToggleButton x:Name="VisualHeaderSplitModeToggle" Click="SplitMode_Click" ToolTip="Split Mode (Visual &amp; Code)" Style="{StaticResource ToolbarToggleButtonStyle}" Padding="4,2">

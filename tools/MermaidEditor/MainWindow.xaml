                            <Button Click="FormatNumberedList_Click" ToolTip="Numbered List" Style="{StaticResource ToolbarButtonStyle}" Padding="6,4">
                                <TextBlock Text="1." FontFamily="Segoe UI" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                            </Button>
                            <Button Click="FormatQuote_Click" ToolTip="Quote" Style="{StaticResource ToolbarButtonStyle}" Padding="6,4">
                                <TextBlock Text="&#xE8AF;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                            </Button>
                            <Separator Background="{DynamicResource ThemeBorderBrush}" Margin="4,4"/>
                            <Button Click="FormatLink_Click" ToolTip="Link (Ctrl+K)" Style="{StaticResource ToolbarButtonStyle}" Padding="6,4">
                                <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                            </Button>
                            <Button Click="FormatImage_Click" ToolTip="Image" Style="{StaticResource ToolbarButtonStyle}" Padding="6,4">
                                <TextBlock Text="&#xEB9F;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                            </Button>
                            <Separator Background="{DynamicResource ThemeBorderBrush}" Margin="4,4"/>
                            <Button Click="FormatHorizontalRule_Click" ToolTip="Horizontal Rule" Style="{StaticResource ToolbarButtonStyle}" Padding="6,4">
                                <TextBlock Text="&#x2015;" FontFamily="Segoe UI" FontSize="14" VerticalAlignment="Center"/>
                            </Button>
                            <Separator Background="{DynamicResource ThemeBorderBrush}" Margin="4,4"/>
                            <Button Click="InsertTable_Click" ToolTip="Insert Table" Style="{StaticResource ToolbarButtonStyle}" Padding="6,4">
                                <TextBlock Text="&#xE80A;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                            </Button>
                        </ToolBar>
                    </ToolBarTray>
                </Border>
                
                <!-- Edit Toolbar (indent, comment, move lines, word wrap) -->
                <Border x:Name="EditToolbarBorder" Background="{DynamicResource ThemeToolbarBackgroundBrush}" CornerRadius="4" HorizontalAlignment="Left" Margin="6,0,0,0">
                    <ToolBarTray Background="Transparent">
                        <ToolBar Band="1" BandIndex="1" Background="Transparent">
                            <Button Click="IndentLines_Click" ToolTip="Indent (Tab)" Style="{StaticResource ToolbarButtonStyle}" Padding="6,4">
                                <TextBlock Text="&#xE291;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                            </Button>
                            <Button Click="OutdentLines_Click" ToolTip="Outdent (Shift+Tab)" Style="{StaticResource ToolbarButtonStyle}" Padding="6,4">
                                <TextBlock Text="&#xE290;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                            </Button>
                            <Separator Background="{DynamicResource ThemeBorderBrush}" Margin="4,4"/>
                            <Button x:Name="ToggleCommentToolbarButton" Click="ToggleComment_Click" ToolTip="Toggle Comment (Ctrl+/)" Style="{StaticResource ToolbarButtonStyle}" Padding="6,4">
                                <TextBlock Text="&#xE90A;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                            </Button>
                            <Separator Background="{DynamicResource ThemeBorderBrush}" Margin="4,4"/>
                            <Button Click="MoveLineUp_Click" ToolTip="Move Line Up (Alt+Up)" Style="{StaticResource ToolbarButtonStyle}" Padding="6,4">
                                <TextBlock Text="&#xE74A;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                            </Button>
                            <Button Click="MoveLineDown_Click" ToolTip="Move Line Down (Alt+Down)" Style="{StaticResource ToolbarButtonStyle}" Padding="6,4">
                                <TextBlock Text="&#xE74B;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                            </Button>
                        </ToolBar>
                    </ToolBarTray>
                </Border>
                
                <!-- View/Toggle Toolbar (split view, line numbers, bracket matching, word wrap, minimap) -->
                <Border x:Name="ViewToggleToolbarBorder" Background="{DynamicResource ThemeToolbarBackgroundBrush}" CornerRadius="4" HorizontalAlignment="Left" Margin="6,0,0,0">
                    <ToolBarTray Background="Transparent">
                        <ToolBar Band="1" BandIndex="1" Background="Transparent">
                            <ToggleButton x:Name="WordWrapToggle" Click="WordWrap_Click" ToolTip="Toggle Word Wrap" Style="{StaticResource ToolbarToggleButtonStyle}" Padding="6,4">
                                <TextBlock Text="&#xE1A5;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                            </ToggleButton>
                            <Separator Background="{DynamicResource ThemeBorderBrush}" Margin="4,4"/>
                            <ToggleButton x:Name="SplitViewToggle" Click="SplitView_Click" ToolTip="Toggle Preview Panel" Style="{StaticResource ToolbarToggleButtonStyle}" Padding="6,4" IsChecked="True">
                                <TextBlock Text="&#xE8A0;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                            </ToggleButton>
                            <ToggleButton x:Name="LineNumbersToggle" Click="LineNumbers_Click" ToolTip="Toggle Line Numbers" Style="{StaticResource ToolbarToggleButtonStyle}" Padding="6,4" IsChecked="True">
                                <TextBlock Text="123" FontFamily="Consolas" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                            </ToggleButton>
                            <ToggleButton x:Name="BracketMatchingToggle" Click="BracketMatching_Click" ToolTip="Toggle Bracket Matching" Style="{StaticResource ToolbarToggleButtonStyle}" Padding="6,4" IsChecked="True">
                                <TextBlock Text="{}{}" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"/>
                            </ToggleButton>
                            <ToggleButton x:Name="MinimapToggle" Click="Minimap_Click" ToolTip="Toggle Minimap" Style="{StaticResource ToolbarToggleButtonStyle}" Padding="6,4" IsChecked="False">
                                <TextBlock Text="&#xE700;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                            </ToggleButton>
                            <Separator Background="{DynamicResource ThemeBorderBrush}" Margin="4,4"/>
                            <ToggleButton x:Name="SpellCheckToggle" Click="SpellCheck_Click" ToolTip="Toggle Spell Check" Style="{StaticResource ToolbarToggleButtonStyle}" Padding="6,4" IsChecked="True">
                                <TextBlock Text="ABC" FontFamily="Consolas" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                            </ToggleButton>
                        </ToolBar>
                    </ToolBarTray>
                </Border>
                
                <!-- Ask AI Toolbar -->
                <Border Background="{DynamicResource ThemeToolbarBackgroundBrush}" CornerRadius="4" HorizontalAlignment="Left" Margin="6,0,0,0">
                    <ToolBarTray Background="Transparent">
                        <ToolBar Band="1" BandIndex="1" Background="Transparent">
                            <Button x:Name="AskAiToolbarButton" Click="AskAi_Click" ToolTip="Ask AI (Ctrl+Shift+A)" Style="{StaticResource ToolbarButtonStyle}" Padding="6,4">
                                <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                            </Button>
                        </ToolBar>
                    </ToolBarTray>
                </Border>
                
                
            </StackPanel>
        </Border>
        
        <!-- Main Content - Split View -->
        <Grid x:Name="MainContentGrid" Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="CodeEditorColumn" Width="*" MinWidth="200"/>
                <ColumnDefinition x:Name="VisualSplitterColumn" Width="0"/>
                <ColumnDefinition x:Name="VisualEditorColumn" Width="0"/>
                <ColumnDefinition x:Name="SplitterColumn" Width="5"/>
                <ColumnDefinition x:Name="PreviewColumn" Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>
            
            <!-- Document Tabs - spans all columns so they're always visible in all modes -->
            <Grid Grid.Row="0" Grid.ColumnSpan="5" Background="{DynamicResource ThemeToolbarBackgroundBrush}">
                <!-- Purple line underneath non-selected tabs -->
                <Border Background="{DynamicResource ThemeToolbarBackgroundBrush}" BorderBrush="{DynamicResource ThemePurpleAccentBrush}" 
                        BorderThickness="0,0,0,1" Margin="0,0,0,0"/>
                <ScrollViewer x:Name="DocumentTabScrollViewer" 
                              HorizontalScrollBarVisibility="Auto" 
                              VerticalScrollBarVisibility="Disabled"
                              Background="Transparent">
                    <StackPanel x:Name="DocumentTabsPanel" Orientation="Horizontal"/>
                </ScrollViewer>
            </Grid>
            
            <!-- Left Panel - Code Editor with Header -->
            <Grid Grid.Row="1" Grid.RowSpan="2" Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Code Editor Header Bar (title + navigation dropdown + mode buttons) -->
                <Border Grid.Row="0" Background="{DynamicResource ThemeToolbarBackgroundBrush}" Padding="8,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Title -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource ThemeForegroundBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="Code Editor" Foreground="{DynamicResource ThemeForegroundBrush}" FontWeight="SemiBold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <!-- Navigation Dropdown -->
                        <ComboBox x:Name="NavigationDropdown" 
                                  Grid.Column="1"
                                  Style="{StaticResource NavigationComboBoxStyle}"
                                  HorizontalContentAlignment="Stretch"
                                  VerticalContentAlignment="Center"
                                  BorderThickness="1"
                                  MinWidth="100"
                                  Margin="8,0"
                                  SelectionChanged="NavigationDropdown_SelectionChanged"
                                  ToolTip="Jump to section">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayText}" Foreground="{DynamicResource ThemeForegroundBrush}" Margin="{Binding IndentMargin}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Background" Value="{DynamicResource ThemeToolbarBackgroundBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="8,4"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ComboBoxItem">
                                                <Border x:Name="Bd" 
                                                        Background="{TemplateBinding Background}" 
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsHighlighted" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeHoverBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeSelectedBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>
                        
                        <!-- Mode Switch Buttons (visible for Mermaid files) -->
                        <StackPanel x:Name="CodeHeaderModeButtons" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
                            <ToggleButton x:Name="TextModeToggle" Click="TextMode_Click" ToolTip="Code View Mode" Style="{StaticResource ToolbarToggleButtonStyle}" Padding="4,2" IsChecked="True">
                                <Viewbox Width="14" Height="14">
                                    <Canvas Width="24" Height="24">

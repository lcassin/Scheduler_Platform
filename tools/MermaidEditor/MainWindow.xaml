                                    </Canvas>
                                </Viewbox>
                            </ToggleButton>
                            <ToggleButton x:Name="SplitModeToggle" Click="SplitMode_Click" ToolTip="Split Mode (Visual &amp; Code)" Style="{StaticResource ToolbarToggleButtonStyle}" Padding="4,2">
                                <Viewbox Width="14" Height="14">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M12.75 2C12.75 1.58579 12.4142 1.25 12 1.25C11.5858 1.25 11.25 1.58579 11.25 2H12.75ZM11.25 2V3H12.75V2H11.25Z" Fill="{DynamicResource ThemeForegroundBrush}" Opacity="0.5"/>

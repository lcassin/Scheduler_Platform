                            </ToggleButton>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <wv2:WebView2 x:Name="VisualEditorWebView" 
                              Grid.Row="1"/>
            </Grid>
            
            <!-- Splitter between Editor(s) and Preview -->
            <GridSplitter Grid.Row="2" Grid.Column="3" 
                          Width="8" 
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource ThemeBorderBrush}"
                          Cursor="SizeWE">
                <GridSplitter.Template>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Background="{DynamicResource ThemeBorderBrush}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Ellipse Width="4" Height="4" Fill="{DynamicResource ThemeDisabledForegroundBrush}" Margin="0,2"/>
                                <Ellipse Width="4" Height="4" Fill="{DynamicResource ThemeDisabledForegroundBrush}" Margin="0,2"/>
                                <Ellipse Width="4" Height="4" Fill="{DynamicResource ThemeDisabledForegroundBrush}" Margin="0,2"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </GridSplitter.Template>
            </GridSplitter>
            
            <!-- Right Panel - Preview -->
            <Grid Grid.Row="2" Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Border Grid.Row="0" Background="{DynamicResource ThemeToolbarBackgroundBrush}" Padding="8,4">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="PreviewBackButton" Click="PreviewBack_Click" ToolTip="Go Back" 
                                Style="{StaticResource ToolbarButtonStyle}" Padding="4,2" Margin="0,0,4,0"
                                IsEnabled="False">
                            <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                        </Button>
                        <TextBlock Text="&#xE8FF;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource ThemeForegroundBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="Preview" Foreground="{DynamicResource ThemeForegroundBrush}" FontWeight="SemiBold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
                <wv2:WebView2 x:Name="PreviewWebView" 
                              Grid.Row="1"/>
            </Grid>
        </Grid>
        
        <!-- Status Bar -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready" Foreground="{DynamicResource ThemeDisabledForegroundBrush}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="FilePathText" Text="Untitled" Foreground="{DynamicResource ThemeDisabledForegroundBrush}"/>
            </StatusBarItem>
            <!-- Spacer to push zoom controls to the right -->
            <StatusBarItem HorizontalAlignment="Right" DockPanel.Dock="Right">
                <StackPanel x:Name="ZoomControlsPanel" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Fit to Window button -->
                    <Button x:Name="FitButton" Click="FitToWindow_Click" ToolTip="Fit to Window (Ctrl+F)" 
                            Style="{StaticResource StatusBarButtonStyle}" Margin="0,0,8,0">
                        <TextBlock Text="&#xE9A6;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" VerticalAlignment="Center"/>
                    </Button>
                    <Separator/>
                    <!-- Zoom Out button -->
                    <Button x:Name="ZoomOutButton" Click="ZoomOut_Click" ToolTip="Zoom Out (Ctrl+-)" 
                            Style="{StaticResource StatusBarButtonStyle}" Margin="4,0,0,0">
                        <TextBlock Text="-" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" VerticalAlignment="Center"/>
                    </Button>
                    <!-- Zoom Slider -->
                    <Slider x:Name="ZoomSlider" 
                            Width="100" 
                            Minimum="10" 
                            Maximum="500" 
                            Value="100"
                            VerticalAlignment="Center"
                            Margin="4,0"
                            Style="{StaticResource ZoomSliderStyle}"
                            ValueChanged="ZoomSlider_ValueChanged"
                            ToolTip="Zoom Level"/>
                    <!-- Zoom In button -->
                    <Button x:Name="ZoomInButton" Click="ZoomIn_Click" ToolTip="Zoom In (Ctrl++)" 
                            Style="{StaticResource StatusBarButtonStyle}" Margin="0,0,4,0">
                        <TextBlock Text="+" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" VerticalAlignment="Center"/>
                    </Button>
                    <!-- Zoom percentage display -->
                    <TextBlock x:Name="ZoomLevelText" Text="100%" Foreground="{DynamicResource ThemeDisabledForegroundBrush}" VerticalAlignment="Center" Width="45" TextAlignment="Right" Margin="4,0,8,0"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>

                                    </Canvas>
                                </Viewbox>
                            </ToggleButton>
                            <ToggleButton x:Name="VisualModeToggle" Click="VisualMode_Click" ToolTip="Visual Editor Mode" Style="{StaticResource ToolbarToggleButtonStyle}" Padding="4,2">
                                <Viewbox Width="14" Height="14">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M9 11.5C9 12.8807 7.88071 14 6.5 14C5.11929 14 4 12.8807 4 11.5C4 10.1193 5.11929 9 6.5 9C7.88071 9 9 10.1193 9 11.5Z" Stroke="{DynamicResource ThemeForegroundBrush}" StrokeThickness="1.5"/>

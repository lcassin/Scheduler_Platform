    private string FormatDashboardDateTime(DateTime dateTime)
    {
        if (!_timezoneLoaded || string.IsNullOrEmpty(_browserTimeZone))
            return dateTime.ToString("MM/dd/yyyy hh:mm:ss tt");
        
        try
        {
            var utcDt = dateTime.Kind == DateTimeKind.Unspecified 
                ? DateTime.SpecifyKind(dateTime, DateTimeKind.Utc) 
                : dateTime;
            var tz = TimeZoneInfo.FindSystemTimeZoneById(_browserTimeZone);
            var localTime = TimeZoneInfo.ConvertTimeFromUtc(utcDt, tz);
            return localTime.ToString("MM/dd/yyyy hh:mm:ss tt");
        }
        catch
        {
            return dateTime.ToString("MM/dd/yyyy hh:mm:ss tt");
        }
    }

    private Color GetDashboardStepColor(AdrOrchestrationStatus run, string stepName)
    {
        var stepOrder = new[] { "Syncing accounts", "Creating jobs", "Processing rebill", "Checking statuses", "Processing scraping" };
        var currentStepIndex = Array.IndexOf(stepOrder, run.CurrentStep);
        var thisStepIndex = Array.IndexOf(stepOrder, stepName);

        if (run.Status == "Completed") return Color.Success;
        if (run.Status == "Failed")
        {
            if (thisStepIndex <= currentStepIndex) return thisStepIndex == currentStepIndex ? Color.Error : Color.Success;
            return Color.Default;
        }
        if (run.Status == "Running" || run.Status == "InProgress")
        {
            if (thisStepIndex < currentStepIndex) return Color.Success;
            if (thisStepIndex == currentStepIndex) return Color.Info;
            return Color.Default;
        }
        return Color.Default;
    }

    private string GetDashboardJobsLinkForRun(AdrOrchestrationStatus run, string? status = null)
    {
        var modifiedAfter = run.StartedAt?.ToString("o") ?? "";
        var modifiedBefore = run.CompletedAt?.ToString("o") ?? DateTime.UtcNow.ToString("o");
        var url = $"/adr/jobs?modifiedAfter={Uri.EscapeDataString(modifiedAfter)}&modifiedBefore={Uri.EscapeDataString(modifiedBefore)}&latestPerAccount=false";
        if (!string.IsNullOrEmpty(status))
            url += $"&status={Uri.EscapeDataString(status)}";
        return url;
    }

    private string GetDashboardAccountsLinkForRun(AdrOrchestrationStatus run)
    {
        var modifiedAfter = run.StartedAt?.ToString("o") ?? "";
        var modifiedBefore = run.CompletedAt?.ToString("o") ?? DateTime.UtcNow.ToString("o");
        return $"/adr/accounts?modifiedAfter={Uri.EscapeDataString(modifiedAfter)}&modifiedBefore={Uri.EscapeDataString(modifiedBefore)}";
    }


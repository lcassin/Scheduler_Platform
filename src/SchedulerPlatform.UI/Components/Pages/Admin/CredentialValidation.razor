@page "/admin/credential-validation"
@using SchedulerPlatform.UI.Services
@using SchedulerPlatform.UI.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@attribute [Authorize]
@inject IAdrService AdrService
@inject ISnackbar Snackbar
@inject IPermissionService PermissionService

<PageTitle>Credential Validation</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">Credential Validation</MudText>

    @if (!_hasAccess)
    {
        <MudAlert Severity="Severity.Warning">
            You do not have permission to access this page. Only Admin and Super Admin users can run credential validation.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            @* Left Column: Input Methods *@
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4 mb-4">
                    <MudText Typo="Typo.h6" Class="mb-2">Upload Excel File</MudText>
                    <MudAlert Severity="Severity.Info" Class="mb-3" Dense="true">
                        <MudText Typo="Typo.body2"><strong>Expected format:</strong> Excel file (.xlsx) with a column named <strong>CredentialId</strong>.</MudText>
                        <MudText Typo="Typo.body2">Column name is case-insensitive (accepts "CredentialId", "Credential Id", "Credential_Id", "CredentialID").</MudText>
                        <MudText Typo="Typo.body2">Each row should contain an integer Credential ID. Non-numeric values and empty rows are skipped.</MudText>
                        <MudText Typo="Typo.body2">Additional columns in the file are ignored.</MudText>
                    </MudAlert>
                    <MudFileUpload T="IBrowserFile" Accept=".xlsx" FilesChanged="OnFileSelected" MaximumFileCount="1">
                        <ActivatorContent>
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.CloudUpload"
                                       Disabled="@_isProcessing">
                                Select Excel File (.xlsx)
                            </MudButton>
                        </ActivatorContent>
                    </MudFileUpload>
                    @if (_selectedFile != null)
                    {
                        <MudText Typo="Typo.body2" Class="mt-2">
                            Selected: @_selectedFile.Name (@FormatFileSize(_selectedFile.Size))
                        </MudText>
                    }
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.PlayArrow"
                               Class="mt-3"
                               Disabled="@(_selectedFile == null || _isProcessing)"
                               OnClick="RunFileValidation">
                        Run ADR Request Validation (File)
                    </MudButton>
                </MudPaper>

                <MudPaper Class="pa-4 mb-4">
                    <MudText Typo="Typo.h6" Class="mb-2">Enter Credential IDs Manually</MudText>
                    <MudAlert Severity="Severity.Info" Class="mb-3" Dense="true">
                        <MudText Typo="Typo.body2">Enter credential IDs separated by commas, spaces, or newlines (e.g., "101, 202, 303").</MudText>
                    </MudAlert>
                    <MudTextField @bind-Value="_manualCredentialIds"
                                  Label="Credential IDs"
                                  Variant="Variant.Outlined"
                                  Lines="5"
                                  Placeholder="Enter credential IDs separated by commas, spaces, or newlines"
                                  Disabled="@_isProcessing" />
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.PlayArrow"
                               Class="mt-3"
                               Disabled="@(string.IsNullOrWhiteSpace(_manualCredentialIds) || _isProcessing)"
                               OnClick="RunManualValidation">
                        Run ADR Request Validation (Manual)
                    </MudButton>
                </MudPaper>
            </MudItem>

            @* Right Column: Progress and Results *@
            <MudItem xs="12" md="6">
                @if (_isProcessing)
                {
                    <MudPaper Class="pa-4 mb-4">
                        <MudText Typo="Typo.h6" Class="mb-2">Processing...</MudText>
                        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
                        <MudText Typo="Typo.body2">
                            Sending ADR Request validation for @_credentialCount credential IDs. This may take several minutes for large lists.
                        </MudText>
                    </MudPaper>
                }

                @if (_result != null)
                {
                    <MudPaper Class="pa-4 mb-4">
                        <MudText Typo="Typo.h6" Class="mb-3">Validation Results</MudText>
                        <MudGrid>
                            <MudItem xs="6" sm="3">
                                <MudPaper Class="pa-3" Elevation="0" Style="background-color: var(--mud-palette-background-grey);">
                                    <MudText Typo="Typo.caption" Color="Color.Default">Processed</MudText>
                                    <MudText Typo="Typo.h5">@_result.AccountsProcessed</MudText>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudPaper Class="pa-3" Elevation="0" Style="background-color: #e8f5e9;">
                                    <MudText Typo="Typo.caption" Style="color: #2e7d32;">Verified</MudText>
                                    <MudText Typo="Typo.h5" Style="color: #2e7d32;">@_result.CredentialsVerified</MudText>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudPaper Class="pa-3" Elevation="0" Style="background-color: #fff3e0;">
                                    <MudText Typo="Typo.caption" Style="color: #e65100;">Failed</MudText>
                                    <MudText Typo="Typo.h5" Style="color: #e65100;">@_result.CredentialsFailed</MudText>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudPaper Class="pa-3" Elevation="0" Style="background-color: #ffebee;">
                                    <MudText Typo="Typo.caption" Style="color: #c62828;">Errors</MudText>
                                    <MudText Typo="Typo.h5" Style="color: #c62828;">@_result.Errors</MudText>
                                </MudPaper>
                            </MudItem>
                        </MudGrid>

                        <MudText Typo="Typo.body2" Class="mt-3" Color="Color.Default">
                            Duration: @_result.Duration.ToString(@"hh\:mm\:ss")
                        </MudText>

                        @if (_result.ErrorMessages.Any())
                        {
                            <MudExpansionPanels Class="mt-3">
                                <MudExpansionPanel Text="@($"Error Details ({_result.ErrorMessages.Count})")">
                                    <MudList T="string" Dense="true">
                                        @foreach (var error in _result.ErrorMessages.Take(100))
                                        {
                                            <MudListItem T="string" Icon="@Icons.Material.Filled.Error" IconColor="Color.Error">
                                                <MudText Typo="Typo.body2">@error</MudText>
                                            </MudListItem>
                                        }
                                        @if (_result.ErrorMessages.Count > 100)
                                        {
                                            <MudListItem T="string">
                                                <MudText Typo="Typo.body2" Color="Color.Default">
                                                    ... and @(_result.ErrorMessages.Count - 100) more errors
                                                </MudText>
                                            </MudListItem>
                                        }
                                    </MudList>
                                </MudExpansionPanel>
                            </MudExpansionPanels>
                        }
                    </MudPaper>
                }

                @if (!_isProcessing && _result == null)
                {
                    <MudPaper Class="pa-4 mb-4">
                        <MudText Typo="Typo.h6" Class="mb-2">How It Works</MudText>
                        <MudList T="string" Dense="true">
                            <MudListItem T="string" Icon="@Icons.Material.Filled.LooksOne">
                                Upload an Excel file or enter credential IDs manually.
                            </MudListItem>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.LooksTwo">
                                The system finds all active, non-deleted accounts matching the provided credential IDs.
                            </MudListItem>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Looks3">
                                An ADR Request (AttemptLogin) is sent for each account in parallel to verify credentials.
                            </MudListItem>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Looks4">
                                Results are displayed showing verified, failed, and error counts.
                            </MudListItem>
                        </MudList>
                        <MudAlert Severity="Severity.Warning" Class="mt-3" Dense="true">
                            <MudText Typo="Typo.body2">This is an admin tool for fallout handling after bulk ADR Request runs. Each credential ID may map to multiple accounts.</MudText>
                        </MudAlert>
                    </MudPaper>
                }
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    private bool _hasAccess = false;
    private bool _isProcessing = false;
    private IBrowserFile? _selectedFile;
    private string? _manualCredentialIds;
    private int _credentialCount = 0;
    private BulkCredentialVerificationResult? _result;

    protected override async Task OnInitializedAsync()
    {
        _hasAccess = await PermissionService.IsSystemAdminAsync() ||
                     await PermissionService.CanUpdateAsync("admin") ||
                     await PermissionService.CanUpdateAsync("adr");
    }

    private void OnFileSelected(IBrowserFile file)
    {
        _selectedFile = file;
        _result = null;
    }

    private async Task RunFileValidation()
    {
        if (_selectedFile == null) return;

        _isProcessing = true;
        _result = null;
        _credentialCount = 0;
        StateHasChanged();

        try
        {
            // Read file content (max 10 MB)
            const long maxFileSize = 10 * 1024 * 1024;
            await using var stream = _selectedFile.OpenReadStream(maxFileSize);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            var fileContent = memoryStream.ToArray();

            _credentialCount = 1; // We don't know exact count until API processes it
            StateHasChanged();

            _result = await AdrService.VerifyCredentialsFromFileAsync(fileContent, _selectedFile.Name);
            Snackbar.Add($"Validation complete: {_result.AccountsProcessed} accounts processed", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error during file validation: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task RunManualValidation()
    {
        if (string.IsNullOrWhiteSpace(_manualCredentialIds)) return;

        _isProcessing = true;
        _result = null;
        StateHasChanged();

        try
        {
            // Parse credential IDs from the text input
            var credentialIds = _manualCredentialIds
                .Split(new[] { ',', ' ', '\n', '\r', '\t' }, StringSplitOptions.RemoveEmptyEntries)
                .Select(s => s.Trim())
                .Where(s => int.TryParse(s, out _))
                .Select(int.Parse)
                .Distinct()
                .ToList();

            if (credentialIds.Count == 0)
            {
                Snackbar.Add("No valid credential IDs found. Please enter integer values separated by commas, spaces, or newlines.", Severity.Warning);
                _isProcessing = false;
                StateHasChanged();
                return;
            }

            _credentialCount = credentialIds.Count;
            StateHasChanged();

            _result = await AdrService.VerifyCredentialsByListAsync(credentialIds);
            Snackbar.Add($"Validation complete: {_result.AccountsProcessed} accounts processed", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error during manual validation: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }
}

@page "/admin/credential-validation"
@using SchedulerPlatform.UI.Services
@using SchedulerPlatform.UI.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@attribute [Authorize]
@inject IAdrService AdrService
@inject ISnackbar Snackbar
@inject IPermissionService PermissionService

<PageTitle>Credential / Account Validation</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">Credential / Account Validation</MudText>

    @if (!_hasAccess)
    {
        <MudAlert Severity="Severity.Warning">
            You do not have permission to access this page. Only Admin and Super Admin users can run credential validation.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            @* Left Column: Input Methods *@
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4 mb-4">
                    <MudText Typo="Typo.h6" Class="mb-2">Upload File</MudText>
                    <MudAlert Severity="Severity.Info" Class="mb-3" Dense="true">
                        <MudText Typo="Typo.body2"><strong>Expected format:</strong> Excel (.xlsx) or CSV (.csv) file with a column named <strong>CredentialId</strong> and/or <strong>AccountId</strong>.</MudText>
                        <MudText Typo="Typo.body2">Column names are case-insensitive (accepts "CredentialId", "Credential Id", "Credential_Id", "AccountId", "Account Id", "Account_Id").</MudText>
                        <MudText Typo="Typo.body2">The file can contain one or both columns. Each row should contain an integer ID. Non-numeric values and empty rows are skipped.</MudText>
                        <MudText Typo="Typo.body2">Additional columns in the file are ignored. Max file size: 20 MB.</MudText>
                    </MudAlert>
                    <MudFileUpload T="IBrowserFile" Accept=".xlsx,.csv" FilesChanged="OnFileSelected" MaximumFileCount="1">
                        <ActivatorContent>
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.CloudUpload"
                                       Disabled="@_isProcessing">
                                Select File (.xlsx or .csv)
                            </MudButton>
                        </ActivatorContent>
                    </MudFileUpload>
                    @if (_selectedFile != null)
                    {
                        <MudText Typo="Typo.body2" Class="mt-2">
                            Selected: @_selectedFile.Name (@FormatFileSize(_selectedFile.Size))
                        </MudText>
                    }
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.PlayArrow"
                               Class="mt-3"
                               Disabled="@(_selectedFile == null || _isProcessing)"
                               OnClick="RunFileValidation">
                        Run ADR Request Validation (File)
                    </MudButton>
                </MudPaper>

                <MudPaper Class="pa-4 mb-4">
                    <MudText Typo="Typo.h6" Class="mb-2">Enter IDs Manually</MudText>
                    <MudAlert Severity="Severity.Info" Class="mb-3" Dense="true">
                        <MudText Typo="Typo.body2">Select the ID type and enter values separated by commas, spaces, or newlines (e.g., "101, 202, 303").</MudText>
                    </MudAlert>
                    <MudToggleGroup T="string" @bind-Value="_manualIdType" Color="Color.Primary" Class="mb-3">
                        <MudToggleItem Value="@("CredentialId")" Text="Credential IDs" />
                        <MudToggleItem Value="@("AccountId")" Text="Account IDs" />
                    </MudToggleGroup>
                    <MudTextField @bind-Value="_manualIds"
                                  Label="@(_manualIdType == "AccountId" ? "Account IDs" : "Credential IDs")"
                                  Variant="Variant.Outlined"
                                  Lines="5"
                                  Placeholder="@($"Enter {(_manualIdType == "AccountId" ? "account" : "credential")} IDs separated by commas, spaces, or newlines")"
                                  Disabled="@_isProcessing"
                                  Immediate="true"
                                  TextChanged="OnManualIdsChanged" />
                    @if (_manualIdsOverLimit)
                    {
                        <MudAlert Severity="Severity.Error" Class="mt-2" Dense="true">
                            <MudText Typo="Typo.body2">Input exceeds the 32KB limit (@FormatFileSize(_manualIds?.Length ?? 0) entered). Please use the Excel file upload for large lists.</MudText>
                        </MudAlert>
                    }
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.PlayArrow"
                               Class="mt-3"
                               Disabled="@(string.IsNullOrWhiteSpace(_manualIds) || _isProcessing || _manualIdsOverLimit)"
                               OnClick="RunManualValidation">
                        Run ADR Request Validation (Manual)
                    </MudButton>
                </MudPaper>
            </MudItem>

            @* Right Column: Progress and Results *@
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4 mb-4">
                    <MudText Typo="Typo.h6" Class="mb-2">Bulk Vendor Credential Check</MudText>
                    <MudAlert Severity="Severity.Info" Class="mb-3" Dense="true">
                        <MudText Typo="Typo.body2">Run credential verification (AttemptLogin) for <strong>ALL</strong> active accounts in the system. This is a one-time bulk operation that may take several hours for large datasets.</MudText>
                    </MudAlert>
                    <MudGrid>
                        <MudItem xs="8">
                            <MudNumericField @bind-Value="_bulkTestRunLimit"
                                             Label="Test Run Limit (optional)"
                                             Variant="Variant.Outlined"
                                             Min="0"
                                             HelperText="Leave at 0 to run all accounts, or set a number to limit (e.g., 100 for testing)"
                                             Disabled="@_isProcessing" />
                        </MudItem>
                        <MudItem xs="4" Class="d-flex align-end">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Warning"
                                       StartIcon="@Icons.Material.Filled.PlayArrow"
                                       Disabled="@_isProcessing"
                                       OnClick="RunBulkCredentialCheck"
                                       FullWidth="true">
                                Run Bulk Check
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                </MudPaper>

                @if (_isProcessing)
                {
                    <MudPaper Class="pa-4 mb-4">
                        <MudText Typo="Typo.h6" Class="mb-2">Processing...</MudText>
                        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
                        <MudText Typo="Typo.body2">
                            @_processingMessage
                        </MudText>
                    </MudPaper>
                }

                @if (_result != null)
                {
                    <MudPaper Class="pa-4 mb-4">
                        <MudText Typo="Typo.h6" Class="mb-3">Validation Results</MudText>
                        <MudGrid>
                            <MudItem xs="6" sm="3">
                                <MudPaper Class="pa-3" Elevation="0" Style="background-color: var(--mud-palette-background-grey);">
                                    <MudText Typo="Typo.caption" Color="Color.Default">Processed</MudText>
                                    <MudText Typo="Typo.h5">@_result.AccountsProcessed</MudText>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudPaper Class="pa-3" Elevation="0" Style="background-color: #e8f5e9;">
                                    <MudText Typo="Typo.caption" Style="color: #2e7d32;">Verified</MudText>
                                    <MudText Typo="Typo.h5" Style="color: #2e7d32;">@_result.CredentialsVerified</MudText>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudPaper Class="pa-3" Elevation="0" Style="background-color: #fff3e0;">
                                    <MudText Typo="Typo.caption" Style="color: #e65100;">Failed</MudText>
                                    <MudText Typo="Typo.h5" Style="color: #e65100;">@_result.CredentialsFailed</MudText>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudPaper Class="pa-3" Elevation="0" Style="background-color: #ffebee;">
                                    <MudText Typo="Typo.caption" Style="color: #c62828;">Errors</MudText>
                                    <MudText Typo="Typo.h5" Style="color: #c62828;">@_result.Errors</MudText>
                                </MudPaper>
                            </MudItem>
                        </MudGrid>

                        <MudText Typo="Typo.body2" Class="mt-3" Color="Color.Default">
                            Duration: @_result.Duration.ToString(@"hh\:mm\:ss")
                        </MudText>

                        @if (_result.ErrorMessages.Any())
                        {
                            <MudExpansionPanels Class="mt-3">
                                <MudExpansionPanel Text="@($"Error Details ({_result.ErrorMessages.Count})")">
                                    <MudList T="string" Dense="true">
                                        @foreach (var error in _result.ErrorMessages.Take(100))
                                        {
                                            <MudListItem T="string" Icon="@Icons.Material.Filled.Error" IconColor="Color.Error">
                                                <MudText Typo="Typo.body2">@error</MudText>
                                            </MudListItem>
                                        }
                                        @if (_result.ErrorMessages.Count > 100)
                                        {
                                            <MudListItem T="string">
                                                <MudText Typo="Typo.body2" Color="Color.Default">
                                                    ... and @(_result.ErrorMessages.Count - 100) more errors
                                                </MudText>
                                            </MudListItem>
                                        }
                                    </MudList>
                                </MudExpansionPanel>
                            </MudExpansionPanels>
                        }
                    </MudPaper>
                }

                @if (!_isProcessing && _result == null)
                {
                    <MudPaper Class="pa-4 mb-4">
                        <MudText Typo="Typo.h6" Class="mb-2">How It Works</MudText>
                        <MudList T="string" Dense="true">
                            <MudListItem T="string" Icon="@Icons.Material.Filled.LooksOne">
                                Upload an Excel file with CredentialId and/or AccountId columns, or enter IDs manually using the toggle to select the ID type.
                            </MudListItem>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.LooksTwo">
                                The system finds all active, non-deleted accounts matching the provided IDs. Lists are processed in batches of 5,000 for performance.
                            </MudListItem>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Looks3">
                                An ADR Request (AttemptLogin) is sent for each account in parallel to verify credentials.
                            </MudListItem>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Looks4">
                                Results are displayed showing verified, failed, and error counts.
                            </MudListItem>
                        </MudList>
                        <MudAlert Severity="Severity.Warning" Class="mt-3" Dense="true">
                            <MudText Typo="Typo.body2">This is an admin tool for fallout handling after bulk ADR Request runs. You can send Credential IDs, Account IDs, or both (via Excel). Each credential ID may map to multiple accounts.</MudText>
                        </MudAlert>
                    </MudPaper>
                }
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    private bool _hasAccess = false;
    private bool _isProcessing = false;
    private IBrowserFile? _selectedFile;
    private string _manualIdType = "CredentialId";
    private string? _manualIds;
    private bool _manualIdsOverLimit = false;
    private const int MaxManualInputLength = 32 * 1024; // 32KB SignalR limit
    private int _idCount = 0;
    private int _bulkTestRunLimit = 0;
    private string _processingMessage = "Processing...";
    private BulkCredentialVerificationResult? _result;

    protected override async Task OnInitializedAsync()
    {
        _hasAccess = await PermissionService.IsSystemAdminAsync() ||
                     await PermissionService.CanUpdateAsync("admin") ||
                     await PermissionService.CanUpdateAsync("adr");
    }

    private void OnManualIdsChanged(string value)
    {
        _manualIds = value;
        _manualIdsOverLimit = (value?.Length ?? 0) > MaxManualInputLength;
        StateHasChanged();
    }

    private void OnFileSelected(IBrowserFile file)
    {
        _selectedFile = file;
        _result = null;
    }

    private async Task RunFileValidation()
    {
        if (_selectedFile == null) return;

        _isProcessing = true;
        _result = null;
        _idCount = 0;
        _processingMessage = $"Uploading and processing file '{_selectedFile.Name}'... This may take several minutes for large files.";
        StateHasChanged();

        try
        {
            // Read file content (max 20 MB)
            const long maxFileSize = 20 * 1024 * 1024;
            await using var stream = _selectedFile.OpenReadStream(maxFileSize);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            var fileContent = memoryStream.ToArray();

            _idCount = 1; // We don't know exact count until API processes it
            _processingMessage = $"Sending credential validation requests from '{_selectedFile.Name}'... This may take several minutes for large files.";
            StateHasChanged();

            _result = await AdrService.VerifyCredentialsFromFileAsync(fileContent, _selectedFile.Name);
            Snackbar.Add($"Validation complete: {_result.AccountsProcessed} accounts processed", Severity.Success);
        }
        catch (Exception ex)
        {
            var errorMsg = ex.Message;
            // Try to extract meaningful error from HttpRequestException
            if (ex.InnerException != null)
                errorMsg = ex.InnerException.Message;
            Snackbar.Add($"Error during file validation: {errorMsg}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task RunManualValidation()
    {
        if (string.IsNullOrWhiteSpace(_manualIds)) return;

        _isProcessing = true;
        _result = null;
        _processingMessage = $"Sending credential validation for {_manualIdType} list... This may take several minutes for large lists.";
        StateHasChanged();

        try
        {
            // Parse IDs from the text input
            var ids = _manualIds
                .Split(new[] { ',', ' ', '\n', '\r', '\t' }, StringSplitOptions.RemoveEmptyEntries)
                .Select(s => s.Trim())
                .Where(s => int.TryParse(s, out _))
                .Select(int.Parse)
                .Distinct()
                .ToList();

            if (ids.Count == 0)
            {
                Snackbar.Add($"No valid {(_manualIdType == "AccountId" ? "account" : "credential")} IDs found. Please enter integer values separated by commas, spaces, or newlines.", Severity.Warning);
                _isProcessing = false;
                StateHasChanged();
                return;
            }

            _idCount = ids.Count;
            StateHasChanged();

            if (_manualIdType == "AccountId")
            {
                _result = await AdrService.VerifyCredentialsByListAsync(accountIds: ids);
            }
            else
            {
                _result = await AdrService.VerifyCredentialsByListAsync(credentialIds: ids);
            }
            Snackbar.Add($"Validation complete: {_result.AccountsProcessed} accounts processed", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error during manual validation: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task RunBulkCredentialCheck()
    {
        _isProcessing = true;
        _result = null;
        _processingMessage = "Queuing bulk credential check for ALL active accounts...";
        StateHasChanged();

        try
        {
            int? testrun = _bulkTestRunLimit > 0 ? _bulkTestRunLimit : null;
            var queuedResponse = await AdrService.QueueBulkCredentialCheckAsync(testrun);

            if (string.IsNullOrEmpty(queuedResponse.RequestId))
            {
                Snackbar.Add("Bulk credential check was queued but no request ID was returned.", Severity.Warning);
                return;
            }

            Snackbar.Add($"Bulk credential check queued (Request ID: {queuedResponse.RequestId}). Monitoring progress...", Severity.Info);
            _processingMessage = $"Bulk credential check queued (Request ID: {queuedResponse.RequestId}). Waiting for background job to start...";
            StateHasChanged();

            // Poll for status until the job completes
            var pollDelayMs = 5000; // Poll every 5 seconds
            var maxPolls = 4320; // Max ~6 hours of polling (4320 * 5s)
            for (int i = 0; i < maxPolls; i++)
            {
                await Task.Delay(pollDelayMs);

                try
                {
                    var status = await AdrService.GetOrchestrationStatusAsync(queuedResponse.RequestId);
                    if (status == null)
                    {
                        _processingMessage = $"Bulk credential check queued. Waiting for status... (poll {i + 1})";
                        StateHasChanged();
                        continue;
                    }

                    var progress = status.CurrentStepTotal > 0
                        ? $"{status.CurrentStepProgress}/{status.CurrentStepTotal} ({(double)status.CurrentStepProgress / status.CurrentStepTotal * 100:F1}%)"
                        : "starting...";
                    _processingMessage = $"Bulk credential check {status.Status}: {status.CurrentStep ?? "Processing"} — {progress}";
                    StateHasChanged();

                    if (status.Status == "Completed" || status.Status == "Failed" || status.Status == "Cancelled")
                    {
                        if (status.Status == "Completed")
                        {
                            Snackbar.Add($"Bulk credential check completed successfully.", Severity.Success);
                            if (status.BulkCredentialVerificationResult != null)
                            {
                                _result = status.BulkCredentialVerificationResult;
                            }
                        }
                        else if (status.Status == "Failed")
                        {
                            Snackbar.Add($"Bulk credential check failed: {status.ErrorMessage}", Severity.Error);
                        }
                        else
                        {
                            Snackbar.Add("Bulk credential check was cancelled.", Severity.Warning);
                        }
                        break;
                    }
                }
                catch (Exception pollEx)
                {
                    // Don't stop polling on transient errors
                    _processingMessage = $"Bulk credential check running... (status check error: {pollEx.Message})";
                    StateHasChanged();
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error during bulk credential check: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }
}

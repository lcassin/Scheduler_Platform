                await AdrService.ClearRuleOverrideAsync(rule.Id);
                await _table.ReloadServerData();
                Snackbar.Add("Override cleared successfully", Severity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error clearing override: {ex.Message}", Severity.Error);
            }
        }
    }


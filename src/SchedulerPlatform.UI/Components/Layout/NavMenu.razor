@using SchedulerPlatform.UI.Services
@inject IPermissionService PermissionService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserPermissionCacheService PermissionCacheService
@inject IPowerBiReportService PowerBiReportService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@implements IDisposable

<MudNavMenu>
    <MudNavLink Href="/" Icon="@CustomIcons.Dashboard" IconColor="Color.Inherit" Match="NavLinkMatch.All">Dashboard</MudNavLink>
    <MudNavLink Href="/adr/monitor" Icon="@CustomIcons.JobMonitor">Job Monitor</MudNavLink>
    <MudNavLink Href="/adr/accounts" Icon="@CustomIcons.Accounts">Accounts</MudNavLink>
    <MudNavLink Href="/adr/rules" Icon="@CustomIcons.AccountRules">Account Rules</MudNavLink>
    <MudNavLink Href="/adr/jobs" Icon="@CustomIcons.Jobs">Jobs</MudNavLink>
    <MudNavLink Href="/adr/missing-accounts" Icon="@CustomIcons.MissingAccounts">Missing Accounts</MudNavLink>
    @if (_powerBiReports.Any())
    {
        <MudNavGroup Title="Power BI Reports" Icon="@CustomIcons.PowerBiReports" Expanded="false">
            @foreach (var report in _powerBiReports)
            {
                @if (report.OpenInNewTab)
                {
                    <MudNavLink Icon="@CustomIcons.PowerBiReportList" OnClick="@(() => OpenReportInNewTab(report.Url))">@report.Name</MudNavLink>
                }
                else
                {
                    <MudNavLink Href="@report.Url" Icon="@CustomIcons.PowerBiReportList">@report.Name</MudNavLink>
                }
            }
        </MudNavGroup>
    }

    <MudDivider Class="my-2" />

    <MudNavGroup Title="Scheduling" Icon="@CustomIcons.Scheduling" Expanded="false">
        <MudNavLink Href="/schedules" Icon="@CustomIcons.Schedules" Match="NavLinkMatch.All">Schedules</MudNavLink>
        <MudNavLink Href="/schedules/missed" Icon="@CustomIcons.MissedSchedules">Missed Schedules</MudNavLink>
        <MudNavLink Href="/calendar" Icon="@CustomIcons.Calendar">Calendar</MudNavLink>
        <MudNavLink Href="/executions" Icon="@CustomIcons.ScheduleExecutions">Schedule Executions</MudNavLink>
    </MudNavGroup>

    @if (_canManageUsers)
    {
        <MudNavGroup Title="Admin" Icon="@CustomIcons.Admin" Expanded="false">
            <MudNavLink Href="/admin/users" Icon="@CustomIcons.UserManagement">User Management</MudNavLink>
            <MudNavLink Href="/admin/adr-configuration" Icon="@CustomIcons.Configuration">ADR Configuration</MudNavLink>
            <MudNavLink Href="/admin/adr-blacklist" Icon="@CustomIcons.Blacklist">ADR Blacklist</MudNavLink>
            <MudNavLink Href="/admin/credential-validation" Icon="@CustomIcons.CredentialValidation">Credential Validation</MudNavLink>
            <MudNavLink Href="/admin/adr-job-types" Icon="@CustomIcons.AdrJobTypes">ADR Job Types</MudNavLink>
            <MudNavLink Href="/admin/power-bi-reports" Icon="@CustomIcons.PowerBiReportList">Power BI Reports</MudNavLink>
            <MudNavLink Href="/admin/logs" Icon="@CustomIcons.ApiLogs">API Logs</MudNavLink>
        </MudNavGroup>
    }
</MudNavMenu>

@code {
    private bool _canManageUsers = false;
    private List<PowerBiReportDto> _powerBiReports = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadPermissionsAsync();
        await LoadPowerBiReportsAsync();
        AuthenticationStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
        // Subscribe to permission cache refresh events to update menu when permissions are loaded
        PermissionCacheService.OnPermissionsRefreshed += OnPermissionsRefreshed;
    }

    private async Task LoadPermissionsAsync()
    {
        _canManageUsers = await PermissionService.CanReadAsync("users:manage");
    }

    private async Task LoadPowerBiReportsAsync()
    {
        try
        {
            // Load active Power BI reports for the ADR category
            _powerBiReports = await PowerBiReportService.GetActiveReportsAsync("ADR");
        }
        catch
        {
            // Silently fail - reports are optional
            _powerBiReports = new List<PowerBiReportDto>();
        }
    }

    private async Task OpenReportInNewTab(string url)
    {
        await JSRuntime.InvokeVoidAsync("open", url, "_blank");
    }

    private async void OnAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        await LoadPermissionsAsync();
        await LoadPowerBiReportsAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async void OnPermissionsRefreshed()
    {
        // Permissions were refreshed from the API, reload and update UI
        await LoadPermissionsAsync();
        await LoadPowerBiReportsAsync();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AuthenticationStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
        PermissionCacheService.OnPermissionsRefreshed -= OnPermissionsRefreshed;
    }
}

